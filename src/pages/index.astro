---
import BlankLayout from '../layouts/BlankLayout.astro';
import '../styles/app.css';
import LandingPage from '../views/landing.svelte';
import { faqData } from '$lib/config/faq';

// Welcome to Astro! Everything between these triple-dash code fences
// is your "component frontmatter". It never runs in the browser.
const isProd = import.meta.env.PROD;
---

<BlankLayout 
  title="Buzooka | Build & Launch Your MVP Product App in Record Time"
  description="Launch production-ready MVPs instantly. Automate codebase generation, cloud infrastructure, and CI/CD pipelines."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href="https://buzooka.in/" />
    <link rel="alternate" hreflang="en-US" href="https://buzooka.in/" />
    <link rel="alternate" hreflang="x-default" href="https://buzooka.in/" />
    
    <!-- Preload critical images -->
    <link rel="preload" as="image" href="/buzooka-logo-new.svg" type="image/svg+xml" />
    <link rel="preload" as="image" href="/og-image.png" type="image/png" />
    <link rel="preload" as="image" href="/buzooka-ai-icon.svg" type="image/svg+xml" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: [0, 1, 2, 5, 7].map((idx) => faqData[idx]).map((faq) => ({
          '@type': 'Question',
          name: faq.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: faq.answer,
          },
        })),
      })}
    />
  </Fragment>

  <LandingPage 
    client:load 
    faqs={[0, 1, 2, 5, 7].map((idx) => faqData[idx])} 
  />
</BlankLayout>

