---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Get featured posts (first 3)
const featuredPosts = posts.slice(0, 3);
// Get latest news (remaining posts)
const latestPosts = posts.slice(3);

// Get all unique tags from posts
const allPostsTags = [
  ...new Set(posts.flatMap((post) => post.data.tags || [])),
];

// Define preferred order for tags
const tagOrder = ['engineering', 'product', 'updates', 'press'] as const;
const activeTags = tagOrder.filter((tag) => allPostsTags.includes(tag as any));
---

<BlogLayout title="Blog | Buzooka" description="Insights, updates, and stories from the Buzooka team.">
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Blog',
      'name': 'Buzooka Blog',
      'description': 'Insights, updates, and stories from the Buzooka team.',
      'url': 'https://buzooka.in/blog',
      'publisher': {
        '@type': 'Organization',
        'name': 'Buzooka',
        'logo': {
          '@type': 'ImageObject',
          'url': 'https://buzooka.in/buzooka-ai-icon.png'
        }
      }
    })}
  />
  <!-- Hero Section -->
  <section class="relative w-full py-8 md:py-8 bg-white/50 backdrop-blur-sm">
    <div class="container mx-auto px-4 md:px-6">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-6xl font-bold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-cyan-500 to-pink-500 leading-tight pb-2"
        >
          Blog
        </h1>
        <p class="text-lg md:text-xl text-slate-600 font-light">
          Insights, updates, and stories from the Buzooka team.
        </p>
      </div>
    </div>
  </section>

  <!-- Category Filters -->
  <section class="w-full border-b border-gray-200 bg-white/50 backdrop-blur-sm sticky top-[62px] z-40">
    <div class="container mx-auto px-4 md:px-6">
      <div class="flex gap-2 overflow-x-auto py-4 scrollbar-hide">
        <button
          data-filter="all"
          class="filter-btn active px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-all"
        >
          All Posts
        </button>
        {
          activeTags.map((tag) => (
            <button
              data-filter={tag}
              class="filter-btn px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-all capitalize"
            >
              {tag}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Featured Posts Grid -->
  <section class="w-full py-12 md:py-16">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          featuredPosts.map((post) => (
            <a
              href={`/blog/${post.slug}/`}
              data-tags={post.data.tags.join(',')}
              class="post-card group bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-xl hover:border-gray-300 transition-all duration-300"
            >
              {/* Icon/Image placeholder */}
              <div class="p-8 pb-6">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500 to-pink-500 flex items-center justify-center mb-6">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 text-white"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"
                    />
                  </svg>
                </div>

                {/* Date */}
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold block mb-3"
                >
                  {post.data.pubDate.toLocaleDateString('en-us', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>

                {/* Title */}
                <h2 class="text-xl font-bold text-gray-900 mb-3 transition-colors">
                  {post.data.title}
                </h2>

                {/* Description */}
                <p class="text-gray-600 leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>

                {/* Author placeholder */}
                <div class="flex items-center gap-2 mt-6 pt-6 border-t border-gray-100">
                  <div class="w-6 h-6 rounded-full bg-gradient-to-br from-cyan-400 to-pink-400" />
                  <span class="text-sm text-gray-700 font-medium">
                    Buzooka Team
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Latest News Section -->
  {
    latestPosts.length > 0 && (
      <section class="w-full py-12 md:py-16 border-t border-gray-200">
        <div class="container mx-auto px-4 md:px-6">
          <h2 class="text-3xl md:text-4xl font-bold mb-8 text-gray-900">
            Latest news.
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {latestPosts.map((post) => (
              <a
                href={`/blog/${post.slug}/`}
                data-tags={post.data.tags.join(',')}
                class="post-card group bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-gray-300 transition-all duration-300"
              >
                {/* Category badge */}
                <div class="inline-block px-3 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-semibold mb-4 capitalize">
                  {post.data.tags[0]}
                </div>

                {/* Date */}
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs text-gray-500 uppercase tracking-wider font-semibold block mb-3"
                >
                  {post.data.pubDate.toLocaleDateString('en-us', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>

                {/* Title */}
                <h3 class="text-lg font-bold text-gray-900 mb-2 transition-colors">
                  {post.data.title}
                </h3>

                {/* Description */}
                <p class="text-sm text-gray-600 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <style is:global>
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .filter-btn {
      background-color: white;
      color: #475569; /* slate-600 */
      border: 1px solid #e2e8f0; /* gray-200 */
    }

    .filter-btn:hover {
      background-color: #f8fafc; /* slate-50 */
      border-color: #cbd5e1; /* slate-300 */
    }

    .filter-btn.active {
      background-color: #0f172a; /* slate-900 */
      color: white;
      border-color: #0f172a;
    }

    .filter-btn.active:hover {
      background-color: #1e293b; /* slate-800 */
      color: white;
    }
  </style>

  <script>
    const filterButtons = document.querySelectorAll('.filter-btn');
    const postCards = document.querySelectorAll('.post-card');

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');

        // Update active button styling
        filterButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');

        // Filter posts
        postCards.forEach((card) => {
          const tags = card.getAttribute('data-tags').split(',');
          if (filter === 'all' || tags.includes(filter)) {
            (card as HTMLElement).style.display = 'block';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</BlogLayout>
